# Copy to .env and fill in. Never commit .env.

# Flask session signing key. Generate one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting interaction_log payloads. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LOG_ENC_KEY=

# Optional. Without it the app runs fully on cached/seeded equivalencies.
GEMINI_API_KEY=

# Outbound mail for email verification — plain SMTP (works with Google
# Workspace app passwords, Mailgun/SendGrid SMTP endpoints, or any relay).
# Leave SMTP_HOST empty in dev: verification links are logged to the console
# instead of sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=no-reply@yourdomain.example

# Copy to .env and fill in. Never commit .env.

# Flask session signing key. Generate one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting interaction_log payloads. Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LOG_ENC_KEY=

# Optional. Without it the app runs fully on cached/seeded equivalencies.
GEMINI_API_KEY=
